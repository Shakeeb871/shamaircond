# Copy this file to ".env" for local development and fill in real values.
# In production, set these as environment variables on your host.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_DOMAIN=yourbrand.com
TIME_ZONE=Asia/Dubai

# --- Brand ---
BRAND_NAME=Brockwell Healthcare
BRAND_TAGLINE=Advanced Regenerative & Stem Cell Therapies

# --- Database (leave unset to use local SQLite) ---
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- UAE contact details (shown on the live UAE site) ---
UAE_PHONE=+971 4 000 0000
UAE_EMAIL=hello@yourbrand.com
UAE_ADDRESS=Dubai Healthcare City, Dubai, United Arab Emirates

# --- USA (flip to True when the US site goes live) ---
US_ENABLED=False
US_PHONE=+1 000 000 0000
US_EMAIL=hello@yourbrand.com
US_ADDRESS=United States

# --- Stripe (get these from dashboard.stripe.com) ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
