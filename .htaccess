# ============================================================
#  SHAM AIRCOND — .htaccess
#  Clean URLs with TRAILING SLASH + HTTPS + gzip + caching + security
# ============================================================

RewriteEngine On
DirectoryIndex index.php index.html

# Don't let Apache auto-append a slash to real directories (we handle URLs ourselves)
DirectorySlash Off
Options -Indexes -MultiViews

# Force HTTPS (uncomment after AutoSSL is active)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ------------------------------------------------------------
#  CLEAN URLS — canonical form is WITH a trailing slash
#  e.g.  /services/aircond-repair/  ->  services/aircond-repair.php
#  /api/ and /admin/ are left untouched (direct .php access).
# ------------------------------------------------------------

# 1) Redirect direct .php requests to the clean trailing-slash URL
RewriteCond %{REQUEST_URI} !^/(api|admin)/ [NC]
RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.php[\s?] [NC]
RewriteRule ^ /%1/ [R=301,L]

# 2) Add a trailing slash to extensionless URLs that map to a .php file
RewriteCond %{REQUEST_URI} !^/(api|admin)/ [NC]
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}.php -f
RewriteRule ^(.+)$ /$1/ [R=301,L]

# 3) Internally serve /clean-url/ from clean-url.php (when that file exists)
RewriteCond %{REQUEST_URI} !^/(api|admin)/ [NC]
RewriteCond %{DOCUMENT_ROOT}/$1.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# ------------------------------------------------------------
#  GZIP COMPRESSION
# ------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json image/svg+xml
</IfModule>

# ------------------------------------------------------------
#  BROWSER CACHING
# ------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType text/css          "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ------------------------------------------------------------
#  SECURITY
# ------------------------------------------------------------
# Block access to sensitive files
<FilesMatch "(^\.|\.(env|ini|log|sh|sql|zip)$|config\.php)">
  Require all denied
</FilesMatch>

# Basic security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
