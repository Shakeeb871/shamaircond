# ============================================================
#  SHAM AIRCOND — .htaccess
#  Clean URLs (extensionless) + HTTPS + gzip + caching + security
# ============================================================

RewriteEngine On

# --- Homepage ---
DirectoryIndex index.php index.html

# ------------------------------------------------------------
#  CLEAN URLS  ( /about  ->  about.php , /services/x -> services/x.php )
#  Only rewrites when a matching .php file actually exists,
#  so /assets, /api and real files are never touched.
# ------------------------------------------------------------

# Force HTTPS (uncomment after AutoSSL is active)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Strip trailing slash (except real directories)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# /page  ->  /page.php   (if page.php exists)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# Optional: redirect ugly /page.php to clean /page
RewriteCond %{THE_REQUEST} \s/+([^.\s]+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ------------------------------------------------------------
#  GZIP COMPRESSION
# ------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json image/svg+xml
</IfModule>

# ------------------------------------------------------------
#  BROWSER CACHING
# ------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType text/css          "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ------------------------------------------------------------
#  SECURITY
# ------------------------------------------------------------
# Block access to sensitive files
<FilesMatch "(^\.|\.(env|ini|log|sh|sql|zip)$|config\.php)">
  Require all denied
</FilesMatch>

# Hide directory listings
Options -Indexes

# Basic security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Custom 404 page (optional) -> falls back to homepage
# ErrorDocument 404 /
